<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme. -->
    <style name="Theme.Context" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@color/deep_bg</item>
        <item name="android:navigationBarColor">@color/deep_bg</item>
    </style>

    <!-- Splash Screen theme. -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Background of the splash screen. -->
        <item name="windowSplashScreenBackground">@color/deep_bg</item>
        <!-- Icon of the splash screen. -->
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <!-- The duration the splash screen is displayed. -->
        <item name="windowSplashScreenAnimationDuration">200</item>
        <!-- Theme to use after the splash screen is finished. -->
        <item name="postSplashScreenTheme">@style/Theme.Context</item>
    </style>
</resources>